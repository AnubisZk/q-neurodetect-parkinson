# Vercel Production Environment

# API
API_HOST=0.0.0.0
API_PORT=3000
DEBUG=False

# Database (opsiyonel PostgreSQL için)
DATABASE_URL=sqlite:///data/predictions.db

# Model yolları (Hugging Face Hub veya S3)
MODEL_STORAGE=local
MODELS_DIR=models/

# Logging
LOG_LEVEL=INFO

# CORS
ALLOWED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com

# Streamlit Frontend (Vercel domain)
FRONTEND_URL=https://yourdomain-frontend.vercel.app
